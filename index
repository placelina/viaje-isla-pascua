<!DOCTYPE html>
<html lang="es">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Rapa Nui — Club de Cine · 5° Aniversario</title>
<link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,300;0,400;0,600;1,300;1,400&family=Outfit:wght@300;400;500;600&display=swap" rel="stylesheet">
<style>
  :root {
    --stone: #2a2420;
    --obsidian: #1a1614;
    --terra: #8b4a2a;
    --coral: #c96b3f;
    --gold: #d4a853;
    --sand: #e8d5b0;
    --sky: #7eb8c9;
    --sea: #3d7a8a;
    --moss: #5a7a52;
    --cream: #f5ede0;
    --white: #fdfaf6;
  }

  * { margin: 0; padding: 0; box-sizing: border-box; }

  body {
    font-family: 'Outfit', sans-serif;
    background: var(--obsidian);
    color: var(--cream);
    min-height: 100vh;
    overflow-x: hidden;
  }

  /* HERO */
  .hero {
    position: relative;
    min-height: 100vh;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    text-align: center;
    padding: 2rem;
    overflow: hidden;
  }

  .hero-bg {
    position: absolute;
    inset: 0;
    background:
      radial-gradient(ellipse at 20% 80%, rgba(139,74,42,0.35) 0%, transparent 50%),
      radial-gradient(ellipse at 80% 20%, rgba(61,122,138,0.3) 0%, transparent 50%),
      radial-gradient(ellipse at 50% 50%, rgba(212,168,83,0.08) 0%, transparent 70%),
      linear-gradient(180deg, #0e0b09 0%, #1a1614 50%, #0d1416 100%);
  }

  /* Moai silhouettes */
  .moai-silhouette {
    position: absolute;
    bottom: 0;
    opacity: 0.18;
    color: var(--terra);
    filter: drop-shadow(0 0 18px rgba(139,74,42,0.3));
  }
  .moai-left  { left: 1%;  width: 130px; }
  .moai-right { right: 3%; width: 100px; transform: scaleX(-1); }
  .moai-back  { left: 50%; transform: translateX(-50%); width: 75px; bottom: 5px; opacity: 0.07; }

  @media (max-width: 480px) {
    .moai-left  { width: 75px; }
    .moai-right { width: 58px; }
    .moai-back  { display: none; }
  }

  .stars {
    position: absolute;
    inset: 0;
    background-image:
      radial-gradient(1px 1px at 10% 15%, rgba(212,168,83,0.6) 0%, transparent 100%),
      radial-gradient(1px 1px at 25% 8%, rgba(255,255,255,0.4) 0%, transparent 100%),
      radial-gradient(1.5px 1.5px at 45% 5%, rgba(255,255,255,0.5) 0%, transparent 100%),
      radial-gradient(1px 1px at 65% 12%, rgba(212,168,83,0.5) 0%, transparent 100%),
      radial-gradient(1px 1px at 80% 6%, rgba(255,255,255,0.3) 0%, transparent 100%),
      radial-gradient(1px 1px at 90% 20%, rgba(255,255,255,0.4) 0%, transparent 100%),
      radial-gradient(1px 1px at 15% 30%, rgba(255,255,255,0.25) 0%, transparent 100%),
      radial-gradient(1px 1px at 55% 25%, rgba(212,168,83,0.3) 0%, transparent 100%),
      radial-gradient(1.5px 1.5px at 75% 18%, rgba(255,255,255,0.45) 0%, transparent 100%),
      radial-gradient(1px 1px at 35% 35%, rgba(255,255,255,0.2) 0%, transparent 100%);
  }

  .hero-content { position: relative; z-index: 2; }

  .club-badge {
    display: inline-block;
    border: 1px solid rgba(212,168,83,0.4);
    padding: 0.4rem 1.2rem;
    font-size: 0.7rem;
    letter-spacing: 0.3em;
    text-transform: uppercase;
    color: var(--gold);
    margin-bottom: 2rem;
    border-radius: 2px;
  }

  .hero h1 {
    font-family: 'Cormorant Garamond', serif;
    font-size: clamp(3rem, 8vw, 7rem);
    font-weight: 300;
    line-height: 0.9;
    color: var(--white);
    margin-bottom: 0.5rem;
  }

  .hero h1 span {
    display: block;
    color: var(--gold);
    font-style: italic;
    font-size: 0.6em;
  }

  .hero-subtitle {
    font-size: 0.85rem;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: rgba(232,213,176,0.5);
    margin: 1.5rem 0 3rem;
  }

  .hero-meta {
    display: flex;
    gap: 2.5rem;
    justify-content: center;
    flex-wrap: wrap;
  }

  .meta-item {
    text-align: center;
  }

  .meta-label {
    font-size: 0.65rem;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: var(--coral);
    display: block;
    margin-bottom: 0.3rem;
  }

  .meta-value {
    font-family: 'Cormorant Garamond', serif;
    font-size: 1.1rem;
    color: var(--sand);
  }

  .scroll-hint {
    position: absolute;
    bottom: 2rem;
    left: 50%;
    transform: translateX(-50%);
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.5rem;
    color: rgba(232,213,176,0.3);
    font-size: 0.65rem;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    z-index: 2;
  }

  .scroll-line {
    width: 1px;
    height: 40px;
    background: linear-gradient(to bottom, rgba(232,213,176,0.3), transparent);
    animation: scrollPulse 2s ease-in-out infinite;
  }

  @keyframes scrollPulse {
    0%, 100% { opacity: 0.3; }
    50% { opacity: 0.8; }
  }

  /* CLIMA BANNER */
  .clima-section {
    background: linear-gradient(135deg, rgba(61,122,138,0.15) 0%, rgba(26,22,20,0) 100%);
    border-top: 1px solid rgba(126,184,201,0.2);
    border-bottom: 1px solid rgba(126,184,201,0.2);
    padding: 2.5rem 2rem;
  }

  .section-inner {
    max-width: 900px;
    margin: 0 auto;
  }

  .section-tag {
    font-size: 0.65rem;
    letter-spacing: 0.3em;
    text-transform: uppercase;
    color: var(--sky);
    margin-bottom: 1.5rem;
    display: flex;
    align-items: center;
    gap: 0.8rem;
  }

  .section-tag::after {
    content: '';
    flex: 1;
    height: 1px;
    background: rgba(126,184,201,0.2);
  }

  .clima-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(160px, 1fr));
    gap: 1rem;
  }

  .clima-card {
    background: rgba(126,184,201,0.07);
    border: 1px solid rgba(126,184,201,0.15);
    border-radius: 6px;
    padding: 1.2rem 1rem;
    text-align: center;
  }

  .clima-icon { font-size: 1.6rem; margin-bottom: 0.5rem; display: block; }
  .clima-card-label { font-size: 0.65rem; letter-spacing: 0.15em; text-transform: uppercase; color: var(--sky); opacity: 0.7; }
  .clima-card-value { font-family: 'Cormorant Garamond', serif; font-size: 1.3rem; color: var(--sand); margin-top: 0.2rem; }
  .clima-card-sub { font-size: 0.7rem; color: rgba(232,213,176,0.5); margin-top: 0.2rem; }

  .clima-tip {
    margin-top: 1.5rem;
    background: rgba(212,168,83,0.08);
    border-left: 3px solid var(--gold);
    padding: 1rem 1.2rem;
    border-radius: 0 4px 4px 0;
    font-size: 0.82rem;
    color: var(--sand);
    line-height: 1.6;
  }

  /* NAVIGATION TABS */
  .nav-section {
    position: sticky;
    top: 0;
    z-index: 100;
    background: rgba(18,14,12,0.95);
    backdrop-filter: blur(20px);
    border-bottom: 1px solid rgba(212,168,83,0.15);
    padding: 0 2rem;
  }

  .nav-tabs {
    max-width: 900px;
    margin: 0 auto;
    display: flex;
    gap: 0;
    overflow-x: auto;
    scrollbar-width: none;
  }

  .nav-tabs::-webkit-scrollbar { display: none; }

  .nav-tab {
    flex-shrink: 0;
    padding: 1.1rem 1.4rem;
    font-size: 0.7rem;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    color: rgba(232,213,176,0.4);
    cursor: pointer;
    border-bottom: 2px solid transparent;
    transition: all 0.3s ease;
    white-space: nowrap;
    background: none;
    border-top: none;
    border-left: none;
    border-right: none;
    font-family: 'Outfit', sans-serif;
  }

  .nav-tab:hover { color: var(--sand); }
  .nav-tab.active { color: var(--gold); border-bottom-color: var(--gold); }

  /* DAY PANELS */
  .days-container {
    max-width: 900px;
    margin: 0 auto;
    padding: 3rem 2rem;
  }

  .day-panel { display: none; }
  .day-panel.active { display: block; animation: fadeIn 0.4s ease; }

  @keyframes fadeIn {
    from { opacity: 0; transform: translateY(10px); }
    to { opacity: 1; transform: translateY(0); }
  }

  .day-header {
    display: flex;
    align-items: flex-start;
    justify-content: space-between;
    margin-bottom: 2.5rem;
    flex-wrap: wrap;
    gap: 1rem;
  }

  .day-number {
    font-family: 'Cormorant Garamond', serif;
    font-size: 5rem;
    font-weight: 300;
    color: rgba(212,168,83,0.15);
    line-height: 1;
    position: relative;
  }

  .day-info { flex: 1; min-width: 200px; }

  .day-date {
    font-size: 0.65rem;
    letter-spacing: 0.25em;
    text-transform: uppercase;
    color: var(--coral);
    margin-bottom: 0.4rem;
  }

  .day-title {
    font-family: 'Cormorant Garamond', serif;
    font-size: 2rem;
    font-weight: 400;
    color: var(--white);
    line-height: 1.2;
  }

  .day-subtitle {
    font-size: 0.8rem;
    color: rgba(232,213,176,0.5);
    margin-top: 0.3rem;
  }

  .day-sun {
    text-align: right;
    background: rgba(212,168,83,0.08);
    border: 1px solid rgba(212,168,83,0.2);
    border-radius: 6px;
    padding: 0.8rem 1.2rem;
  }

  .sun-item { font-size: 0.72rem; color: var(--sand); }
  .sun-item + .sun-item { margin-top: 0.3rem; }
  .sun-emoji { margin-right: 0.4rem; }

  /* TIMELINE */
  .timeline { position: relative; }

  .timeline::before {
    content: '';
    position: absolute;
    left: 28px;
    top: 0;
    bottom: 0;
    width: 1px;
    background: linear-gradient(to bottom, var(--coral), rgba(201,107,63,0.1));
  }

  .tl-item {
    display: flex;
    gap: 1.5rem;
    margin-bottom: 1.8rem;
    position: relative;
  }

  .tl-dot {
    flex-shrink: 0;
    width: 57px;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.3rem;
    position: relative;
    z-index: 1;
  }

  .tl-dot-circle {
    width: 16px;
    height: 16px;
    border-radius: 50%;
    background: var(--stone);
    border: 2px solid var(--coral);
    flex-shrink: 0;
    margin-top: 3px;
  }

  .tl-dot-circle.gold { border-color: var(--gold); background: rgba(212,168,83,0.2); }
  .tl-dot-circle.sea { border-color: var(--sky); }
  .tl-dot-circle.moss { border-color: #7aad70; }

  .tl-time {
    font-size: 0.6rem;
    letter-spacing: 0.1em;
    color: rgba(232,213,176,0.3);
    text-align: center;
    white-space: nowrap;
  }

  .tl-card {
    flex: 1;
    background: rgba(42,36,32,0.5);
    border: 1px solid rgba(139,74,42,0.2);
    border-radius: 8px;
    padding: 1.2rem 1.4rem;
    transition: border-color 0.3s ease;
  }

  .tl-card:hover { border-color: rgba(201,107,63,0.4); }
  .tl-card.highlight { border-color: rgba(212,168,83,0.35); background: rgba(212,168,83,0.05); }
  .tl-card.sea-card { border-color: rgba(126,184,201,0.25); background: rgba(61,122,138,0.08); }

  .tl-card-header {
    display: flex;
    align-items: flex-start;
    justify-content: space-between;
    gap: 1rem;
    margin-bottom: 0.5rem;
  }

  .tl-card-title {
    font-family: 'Cormorant Garamond', serif;
    font-size: 1.15rem;
    color: var(--white);
  }

  .tl-tag {
    font-size: 0.58rem;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    padding: 0.25rem 0.6rem;
    border-radius: 3px;
    flex-shrink: 0;
    white-space: nowrap;
  }

  .tag-arq { background: rgba(139,74,42,0.3); color: #e8956a; border: 1px solid rgba(139,74,42,0.4); }
  .tag-vista { background: rgba(212,168,83,0.15); color: var(--gold); border: 1px solid rgba(212,168,83,0.3); }
  .tag-agua { background: rgba(61,122,138,0.25); color: var(--sky); border: 1px solid rgba(61,122,138,0.4); }
  .tag-trek { background: rgba(90,122,82,0.25); color: #9fd494; border: 1px solid rgba(90,122,82,0.4); }
  .tag-food { background: rgba(80,60,100,0.3); color: #c8a8e0; border: 1px solid rgba(100,80,130,0.4); }
  .tag-vuelo { background: rgba(40,40,70,0.4); color: #8899cc; border: 1px solid rgba(70,80,140,0.3); }
  .tag-libre { background: rgba(30,50,40,0.4); color: #88bb99; border: 1px solid rgba(50,90,60,0.3); }

  .tl-card-desc {
    font-size: 0.82rem;
    color: rgba(232,213,176,0.65);
    line-height: 1.6;
  }

  .tl-card-tip {
    margin-top: 0.6rem;
    font-size: 0.75rem;
    color: var(--gold);
    opacity: 0.8;
  }

  .tl-card-tip::before { content: '★ '; }

  /* RESTAURANTS SECTION */
  .restaurants-section {
    background: rgba(42,36,32,0.3);
    border-top: 1px solid rgba(139,74,42,0.2);
    padding: 3rem 2rem;
  }

  .restaurants-inner { max-width: 900px; margin: 0 auto; }

  .rest-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(260px, 1fr));
    gap: 1.2rem;
    margin-top: 1.5rem;
  }

  .rest-card {
    background: rgba(42,36,32,0.6);
    border: 1px solid rgba(139,74,42,0.2);
    border-radius: 8px;
    padding: 1.4rem;
    transition: border-color 0.3s;
  }

  .rest-card:hover { border-color: rgba(201,107,63,0.4); }
  .rest-card.vegan-friendly { border-color: rgba(90,122,82,0.4); background: rgba(90,122,82,0.06); }

  .rest-name {
    font-family: 'Cormorant Garamond', serif;
    font-size: 1.2rem;
    color: var(--white);
    margin-bottom: 0.3rem;
  }

  .rest-tags { display: flex; gap: 0.4rem; flex-wrap: wrap; margin-bottom: 0.7rem; }

  .rest-tag {
    font-size: 0.6rem;
    letter-spacing: 0.1em;
    padding: 0.2rem 0.55rem;
    border-radius: 3px;
    text-transform: uppercase;
  }

  .rt-vegan { background: rgba(90,122,82,0.3); color: #9fd494; border: 1px solid rgba(90,122,82,0.4); }
  .rt-vista { background: rgba(61,122,138,0.2); color: var(--sky); border: 1px solid rgba(61,122,138,0.3); }
  .rt-show { background: rgba(139,74,42,0.3); color: #e8956a; border: 1px solid rgba(139,74,42,0.4); }
  .rt-sushi { background: rgba(80,60,100,0.3); color: #c8a8e0; border: 1px solid rgba(100,80,130,0.3); }
  .rt-precio { background: rgba(50,50,50,0.4); color: rgba(232,213,176,0.6); border: 1px solid rgba(100,100,100,0.2); }

  .rest-desc {
    font-size: 0.78rem;
    color: rgba(232,213,176,0.6);
    line-height: 1.6;
  }

  .rest-vegan-note {
    margin-top: 0.7rem;
    font-size: 0.74rem;
    color: #9fd494;
    border-top: 1px solid rgba(90,122,82,0.2);
    padding-top: 0.6rem;
  }

  .rest-vegan-note::before { content: '🌱 '; }

  /* TIPS SECTION */
  .tips-section {
    padding: 3rem 2rem;
    background: linear-gradient(180deg, rgba(212,168,83,0.04) 0%, transparent 100%);
  }

  .tips-inner { max-width: 900px; margin: 0 auto; }

  .tips-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
    gap: 1rem;
    margin-top: 1.5rem;
  }

  .tip-card {
    background: rgba(42,36,32,0.4);
    border: 1px solid rgba(212,168,83,0.15);
    border-radius: 8px;
    padding: 1.2rem;
  }

  .tip-icon { font-size: 1.4rem; margin-bottom: 0.6rem; display: block; }
  .tip-title { font-size: 0.75rem; font-weight: 600; color: var(--gold); margin-bottom: 0.4rem; letter-spacing: 0.05em; }
  .tip-text { font-size: 0.76rem; color: rgba(232,213,176,0.6); line-height: 1.6; }

  /* FOOTER */
  footer {
    text-align: center;
    padding: 2rem;
    border-top: 1px solid rgba(42,36,32,0.8);
    font-size: 0.7rem;
    color: rgba(232,213,176,0.2);
    letter-spacing: 0.15em;
  }

  /* ===== RESPONSIVE MÓVIL ===== */
  @media (max-width: 768px) {
    /* Hero */
    .hero { padding: 1.5rem 1rem; min-height: 100svh; }
    .hero h1 { font-size: clamp(2.4rem, 11vw, 4.5rem); }
    .hero-meta { gap: 1.2rem; }
    .meta-value { font-size: 0.95rem; }
    .club-badge { font-size: 0.62rem; padding: 0.35rem 0.9rem; }

    /* Clima */
    .clima-section { padding: 2rem 1rem; }
    .clima-grid { grid-template-columns: repeat(2, 1fr); gap: 0.7rem; }
    .clima-card { padding: 1rem 0.7rem; }
    .clima-card-value { font-size: 1.1rem; }

    /* Nav tabs */
    .nav-section { padding: 0 0.5rem; }
    .nav-tab { padding: 0.85rem 0.75rem; font-size: 0.6rem; letter-spacing: 0.08em; }

    /* Days */
    .days-container { padding: 2rem 1rem; }
    .day-header { flex-direction: column; gap: 0.8rem; }
    .day-number { font-size: 3rem; }
    .day-title { font-size: 1.6rem; }
    .day-sun { text-align: left; }

    /* Timeline */
    .timeline::before { left: 20px; }
    .tl-item { gap: 0.9rem; margin-bottom: 1.4rem; }
    .tl-dot { width: 42px; }
    .tl-dot-circle { width: 13px; height: 13px; }
    .tl-time { font-size: 0.55rem; }
    .tl-card { padding: 1rem 1rem; }
    .tl-card-header { flex-direction: column; align-items: flex-start; gap: 0.4rem; }
    .tl-card-title { font-size: 1rem; }
    .tl-card-desc { font-size: 0.79rem; }
    .tl-tag { align-self: flex-start; }

    /* Restaurantes */
    .rest-grid { grid-template-columns: 1fr; gap: 1rem; }
    .restaurants-section { padding: 2rem 1rem; }

    /* Tips */
    .tips-section { padding: 2rem 1rem; }
    .tips-grid { grid-template-columns: repeat(2, 1fr); gap: 0.8rem; }
    .tip-card { padding: 1rem; }
  }

  @media (max-width: 420px) {
    .hero h1 { font-size: 2.2rem; }
    .hero-meta { flex-direction: column; gap: 0.8rem; }
    .clima-grid { grid-template-columns: 1fr 1fr; }
    .nav-tab { padding: 0.8rem 0.6rem; font-size: 0.56rem; }
    .tips-grid { grid-template-columns: 1fr; }
    .day-title { font-size: 1.4rem; }
    .tl-card-title { font-size: 0.95rem; }
    .rest-name { font-size: 1.05rem; }
  }
</style>
</head>
<body>

<!-- HERO -->
<section class="hero">
  <div class="hero-bg"></div>
  <div class="stars"></div>

  <!-- Moai SVGs: realistic silhouette -->
  <!-- LEFT moai (tall, prominent) -->
  <svg class="moai-silhouette moai-left" viewBox="0 0 110 340" fill="currentColor" xmlns="http://www.w3.org/2000/svg">
    <!-- pukao / topknot hat -->
    <ellipse cx="55" cy="18" rx="18" ry="9"/>
    <rect x="38" y="12" width="34" height="14" rx="3"/>
    <!-- forehead -->
    <path d="M28 26 Q30 10 55 8 Q80 10 82 26 L80 50 Q70 44 55 43 Q40 44 30 50 Z"/>
    <!-- brow ridge strong overhang -->
    <path d="M25 48 Q38 40 55 39 Q72 40 85 48 L87 56 Q72 50 55 50 Q38 50 23 56 Z"/>
    <!-- eye sockets deep set -->
    <ellipse cx="42" cy="60" rx="7" ry="5"/>
    <ellipse cx="68" cy="60" rx="7" ry="5"/>
    <!-- nose long prominent -->
    <path d="M50 66 L45 90 Q50 93 60 93 Q65 90 60 66 Z"/>
    <!-- lips tight -->
    <path d="M42 96 Q55 100 68 96 L66 102 Q55 105 44 102 Z"/>
    <!-- chin jutting -->
    <path d="M40 103 Q55 110 70 103 L72 118 Q55 125 38 118 Z"/>
    <!-- neck -->
    <rect x="42" y="118" width="26" height="20" rx="2"/>
    <!-- torso broad -->
    <path d="M22 138 Q30 130 55 128 Q80 130 88 138 L92 230 Q70 238 55 238 Q40 238 18 230 Z"/>
    <!-- arms suggested -->
    <path d="M22 145 L8 200 Q12 205 20 200 L28 155 Z"/>
    <path d="M88 145 L102 200 Q98 205 90 200 L82 155 Z"/>
    <!-- hands at sides -->
    <ellipse cx="12" cy="205" rx="8" ry="6"/>
    <ellipse cx="98" cy="205" rx="8" ry="6"/>
    <!-- navel / belly button detail -->
    <ellipse cx="55" cy="185" rx="5" ry="4"/>
    <!-- ahu platform base -->
    <rect x="5" y="238" width="100" height="22" rx="3"/>
